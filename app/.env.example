# Copy this file to .env.local and fill in real values.
# Vite only exposes vars prefixed with VITE_ to the browser.

# Google Maps Platform API key with these APIs enabled:
#   - Geocoding API   (address → lat/lng)
#   - Map Tiles API   (Photorealistic 3D Tiles)
# Restrict the key to HTTP referrers in production.
VITE_GOOGLE_MAPS_API_KEY=
